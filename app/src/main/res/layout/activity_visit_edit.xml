<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F3F7FF">

    <!-- 顶部标题 -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:paddingTop="40dp"
        android:paddingBottom="10dp"
        android:text="编辑病历"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#111827"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- 表单滚动区 -->
    <ScrollView
        android:id="@+id/svRoot"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingBottom="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintBottom_toTopOf="@id/bottomBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 卡片：病情与方案 -->
            <LinearLayout
                android:id="@+id/groupIllness"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_card"
                android:padding="14dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="病情与方案"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:textColor="#111827"/>

                <!-- 主诉 -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="主诉"
                    android:textSize="12sp"
                    android:textColor="#6B7280"
                    android:layout_marginTop="10dp"/>

                <EditText
                    android:id="@+id/etChiefComplaint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_input"
                    android:padding="12dp"
                    android:hint="例如：牙痛/牙龈出血…"
                    android:textColor="#111827"
                    android:textColorHint="#9CA3AF"/>

                <!-- 现病史 -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="现病史"
                    android:textSize="12sp"
                    android:textColor="#6B7280"
                    android:layout_marginTop="10dp"/>

                <EditText
                    android:id="@+id/etPresentIllness"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_input"
                    android:padding="12dp"
                    android:minLines="3"
                    android:gravity="top"
                    android:hint="例如：疼痛持续多久、诱因…"
                    android:textColor="#111827"
                    android:textColorHint="#9CA3AF"/>

                <!-- 治疗方案 -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="治疗方案"
                    android:textSize="12sp"
                    android:textColor="#6B7280"
                    android:layout_marginTop="10dp"/>

                <EditText
                    android:id="@+id/etTreatmentPlan"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_input"
                    android:padding="12dp"
                    android:minLines="3"
                    android:gravity="top"
                    android:hint="例如：洁治+复诊+注意事项…"
                    android:textColor="#111827"
                    android:textColorHint="#9CA3AF"/>
            </LinearLayout>

            <!-- 卡片：沟通与预后 -->
            <LinearLayout
                android:id="@+id/groupRelation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_card"
                android:padding="14dp"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="沟通与预后"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:textColor="#111827"/>

                <!-- 患者配合度 -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="患者配合度"
                    android:textSize="12sp"
                    android:textColor="#6B7280"
                    android:layout_marginTop="10dp"/>

                <EditText
                    android:id="@+id/etPatientCooperation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_input"
                    android:padding="12dp"
                    android:hint="例如：配合/一般/差…"
                    android:textColor="#111827"
                    android:textColorHint="#9CA3AF"/>

                <!-- 医患沟通 -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="医患沟通"
                    android:textSize="12sp"
                    android:textColor="#6B7280"
                    android:layout_marginTop="10dp"/>

                <EditText
                    android:id="@+id/etDoctorPatientRelation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_input"
                    android:padding="12dp"
                    android:minLines="3"
                    android:gravity="top"
                    android:hint="例如：已说明风险与费用…"
                    android:textColor="#111827"
                    android:textColorHint="#9CA3AF"/>

                <!-- 预后备注 -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="预后备注"
                    android:textSize="12sp"
                    android:textColor="#6B7280"
                    android:layout_marginTop="10dp"/>

                <EditText
                    android:id="@+id/etPrognosisNote"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_input"
                    android:padding="12dp"
                    android:minLines="3"
                    android:gravity="top"
                    android:hint="例如：预计复诊时间、注意事项…"
                    android:textColor="#111827"
                    android:textColorHint="#9CA3AF"/>
            </LinearLayout>

            <!-- 给底部按钮留空间（避免被 bottomBar 盖住） -->
            <View
                android:layout_width="match_parent"
                android:layout_height="80dp"/>
        </LinearLayout>
    </ScrollView>

    <!-- 底部固定按钮栏（和 patient_edit 一样） -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="10dp"
        android:paddingBottom="14dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="保存"
            android:textStyle="bold"
            android:background="@drawable/bg_primary_button"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>