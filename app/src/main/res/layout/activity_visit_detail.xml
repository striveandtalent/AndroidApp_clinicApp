<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/svRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F3F7FF"
    android:padding="14dp"
    android:fillViewport="true">

    <LinearLayout
        android:id="@+id/llRoot"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 顶部信息卡：病历号 + 就诊时间 -->
        <LinearLayout
            android:id="@+id/cardHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:orientation="vertical"
            android:elevation="2dp">

            <TextView
                android:id="@+id/tvPageTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="病历详情"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#1F2937" />

            <TextView
                android:id="@+id/tvVisitNo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="病历号："
                android:textSize="14sp"
                android:textColor="#2563EB"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvVisitTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="就诊时间："
                android:textSize="13sp"
                android:textColor="#6B7280" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="12dp" />

        <!-- 板块 1：病情与方案（主诉/现病史/治疗方案） -->
        <LinearLayout
            android:id="@+id/cardIllness"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:orientation="vertical"
            android:elevation="2dp">

            <TextView
                android:id="@+id/tvSection1Title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="病情与方案"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#111827" />

            <!-- 主诉 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="主诉"
                android:textSize="13sp"
                android:textColor="#6B7280" />

            <TextView
                android:id="@+id/tvChiefComplaint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="（暂无）"
                android:textSize="15sp"
                android:textColor="#111827"
                android:lineSpacingExtra="3dp" />

            <!-- 现病史 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="现病史"
                android:textSize="13sp"
                android:textColor="#6B7280" />

            <TextView
                android:id="@+id/tvPresentIllness"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="（暂无）"
                android:textSize="15sp"
                android:textColor="#111827"
                android:lineSpacingExtra="3dp" />

            <!-- 治疗方案 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="本诊所治疗方案"
                android:textSize="13sp"
                android:textColor="#6B7280" />

            <TextView
                android:id="@+id/tvTreatmentPlan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="（暂无）"
                android:textSize="15sp"
                android:textColor="#111827"
                android:lineSpacingExtra="3dp" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="12dp" />

        <!-- 板块 2：沟通与预后（配合/医患关系/预测说明） -->
        <LinearLayout
            android:id="@+id/cardRelation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:orientation="vertical"
            android:elevation="2dp">

            <TextView
                android:id="@+id/tvSection2Title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="沟通与预后"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#111827" />

            <!-- 患者配合程度 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="患者配合程度"
                android:textSize="13sp"
                android:textColor="#6B7280" />

            <TextView
                android:id="@+id/tvPatientCooperation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="（暂无）"
                android:textSize="15sp"
                android:textColor="#111827"
                android:lineSpacingExtra="3dp" />

            <!-- 医患关系情况 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="医患关系情况"
                android:textSize="13sp"
                android:textColor="#6B7280" />

            <TextView
                android:id="@+id/tvDoctorPatientRelation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="（暂无）"
                android:textSize="15sp"
                android:textColor="#111827"
                android:lineSpacingExtra="3dp" />

            <!-- 预测发展说明 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="预测发展说明"
                android:textSize="13sp"
                android:textColor="#6B7280" />

            <TextView
                android:id="@+id/tvPrognosisNote"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="（暂无）"
                android:textSize="15sp"
                android:textColor="#111827"
                android:lineSpacingExtra="3dp" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="12dp" />

        <!-- 板块 3：附件（后续你传图片） -->
        <LinearLayout
            android:id="@+id/cardAttachments"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:orientation="vertical"
            android:elevation="2dp">

            <TextView
                android:id="@+id/tvSection3Title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="附件"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#111827" />

            <!-- 空状态提示（没图片时显示，有图片你可以隐藏它） -->
            <TextView
                android:id="@+id/tvAttachmentEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="暂无附件"
                android:textSize="13sp"
                android:textColor="#6B7280" />

            <!-- 预留容器：后续放 RecyclerView(横向缩略图) 或 Grid -->
            <FrameLayout
                android:id="@+id/flAttachmentContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="12dp" />

        <!-- 板块 4：记录信息（创建/更新时间） -->
        <LinearLayout
            android:id="@+id/cardMeta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:orientation="vertical"
            android:elevation="2dp">

            <TextView
                android:id="@+id/tvSection4Title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="记录信息"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#111827" />

            <TextView
                android:id="@+id/tvCreateTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="创建时间："
                android:textSize="13sp"
                android:textColor="#6B7280" />

            <TextView
                android:id="@+id/tvUpdateTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="最后更新时间："
                android:textSize="13sp"
                android:textColor="#6B7280" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="18dp" />

    </LinearLayout>
</ScrollView>