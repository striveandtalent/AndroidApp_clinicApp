<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/svRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F3F7FF"
    android:padding="14dp"
    android:fillViewport="true">

    <LinearLayout
        android:id="@+id/llRoot"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 顶部信息卡（更像 header） -->
        <LinearLayout
            android:id="@+id/cardHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card"
            android:padding="16dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvPageTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="病历详情"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#111827" />

            <TextView
                android:id="@+id/tvVisitNo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="病历号："
                android:textSize="14sp"
                android:textColor="#2563EB"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvVisitTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="就诊时间："
                android:textSize="13sp"
                android:textColor="#6B7280" />
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="12dp" />

        <!-- 板块 1：病情与方案（可点击） -->
        <LinearLayout
            android:id="@+id/cardIllness"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card"
            android:padding="16dp"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground">

            <!-- 标题行：左标题 + 右箭头 -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/tvSection1Title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="病情与方案"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#111827" />

                <TextView
                    android:id="@+id/tvArrow1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="›"
                    android:textSize="22sp"
                    android:textColor="#9CA3AF" />
            </RelativeLayout>



            <!-- 详情展示（仍用你原来的 id） -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="主诉"
                android:textSize="13sp"
                android:textColor="#6B7280" />

            <TextView
                android:id="@+id/tvChiefComplaint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text=""
                android:textSize="15sp"
                android:textColor="#111827"
                android:lineSpacingExtra="3dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="现病史"
                android:textSize="13sp"
                android:textColor="#6B7280" />

            <TextView
                android:id="@+id/tvPresentIllness"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text=""
                android:textSize="15sp"
                android:textColor="#111827"
                android:lineSpacingExtra="3dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="本诊所治疗方案"
                android:textSize="13sp"
                android:textColor="#6B7280" />

            <TextView
                android:id="@+id/tvTreatmentPlan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text=""
                android:textSize="15sp"
                android:textColor="#111827"
                android:lineSpacingExtra="3dp" />
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="12dp" />

        <!-- 板块 2：沟通与预后（可点击） -->
        <LinearLayout
            android:id="@+id/cardRelation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card"
            android:padding="16dp"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/tvSection2Title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="沟通与预后"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#111827" />

                <TextView
                    android:id="@+id/tvArrow2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="›"
                    android:textSize="22sp"
                    android:textColor="#9CA3AF" />
            </RelativeLayout>



            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="患者配合程度"
                android:textSize="13sp"
                android:textColor="#6B7280" />

            <TextView
                android:id="@+id/tvPatientCooperation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text=""
                android:textSize="15sp"
                android:textColor="#111827"
                android:lineSpacingExtra="3dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="医患关系情况"
                android:textSize="13sp"
                android:textColor="#6B7280" />

            <TextView
                android:id="@+id/tvDoctorPatientRelation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text=""
                android:textSize="15sp"
                android:textColor="#111827"
                android:lineSpacingExtra="3dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="预测发展说明"
                android:textSize="13sp"
                android:textColor="#6B7280" />

            <TextView
                android:id="@+id/tvPrognosisNote"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text=""
                android:textSize="15sp"
                android:textColor="#111827"
                android:lineSpacingExtra="3dp" />
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="12dp" />

        <!-- 板块 3：附件（可点击） -->
        <LinearLayout
            android:id="@+id/cardAttachments"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card"
            android:padding="16dp"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/tvSection3Title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="附件"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#111827" />

                <TextView
                    android:id="@+id/tvArrow3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="›"
                    android:textSize="22sp"
                    android:textColor="#9CA3AF" />
            </RelativeLayout>

            <TextView
                android:id="@+id/tvAttachmentEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="暂无附件，点击添加/查看"
                android:textSize="13sp"
                android:textColor="#6B7280" />

            <FrameLayout
                android:id="@+id/flAttachmentContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp" />
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="12dp" />

        <!-- 板块 4：记录信息（一般只读，也可不设点击） -->
        <LinearLayout
            android:id="@+id/cardMeta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card"
            android:padding="16dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvSection4Title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="记录信息"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#111827" />

            <TextView
                android:id="@+id/tvCreateTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="创建时间："
                android:textSize="13sp"
                android:textColor="#6B7280" />

            <TextView
                android:id="@+id/tvUpdateTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="最后更新时间："
                android:textSize="13sp"
                android:textColor="#6B7280" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="18dp" />

    </LinearLayout>
</ScrollView>