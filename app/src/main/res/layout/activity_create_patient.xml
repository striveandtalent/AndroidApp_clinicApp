<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F3F7FF">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:paddingStart="18dp"
        android:paddingTop="40dp"
        android:paddingEnd="18dp"
        android:paddingBottom="10dp"
        android:text="创建病人档案"
        android:textColor="#111827"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ScrollView
        android:id="@+id/svRoot"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingBottom="8dp"
        app:layout_constraintBottom_toTopOf="@id/bottomBar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTitle">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ============ 通用 label 样式（每个字段都用同一套） ============ -->
            <!-- 说明：XML 里不能定义样式块，所以这里直接重复 TextView 属性 -->

            <!-- 卡片1：基础信息 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="基础信息"
                    android:textColor="#111827"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <!-- 姓名 -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="姓名"
                    android:textColor="#6B7280"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/etName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_input"
                    android:inputType="textPersonName"
                    android:padding="12dp"
                    android:textColor="#111827"
                    android:textColorHint="#9CA3AF" />

                <!-- 性别 + 年龄 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal">

                    <!-- 性别 -->

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="性别"
                            android:textColor="#6B7280"
                            android:textSize="12sp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:layout_marginTop="6dp"
                            android:background="@drawable/bg_input"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp">

                            <RadioGroup
                                android:id="@+id/rgGender"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <RadioButton
                                    android:id="@+id/rbMale"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:buttonTint="#666666"
                                    android:minHeight="0dp"
                                    android:text="男"
                                    android:textColor="#111827" />

                                <RadioButton
                                    android:id="@+id/rbFemale"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="20dp"
                                    android:buttonTint="#666666"
                                    android:minHeight="0dp"
                                    android:text="女"
                                    android:textColor="#111827" />
                            </RadioGroup>
                        </LinearLayout>
                    </LinearLayout>

                    <View
                        android:layout_width="10dp"
                        android:layout_height="1dp" />

                    <!-- 年龄 -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="年龄"
                            android:textColor="#6B7280"
                            android:textSize="12sp" />

                        <EditText
                            android:id="@+id/etAge"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:background="@drawable/bg_input"
                            android:inputType="number"
                            android:padding="12dp"
                            android:textColor="#111827"
                            android:textColorHint="#9CA3AF" />
                    </LinearLayout>
                </LinearLayout>

                <!-- 出生日期 -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="出生日期"
                    android:textColor="#6B7280"
                    android:textSize="12sp" />

                <!--<EditText
                    android:id="@+id/etBirthday"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_input"
                    android:hint="例如：1999-01-01"
                    android:padding="12dp"
                    android:inputType="datetime|date"
                    android:textColor="#111827"
                    android:textColorHint="#9CA3AF"/>-->
                <EditText
                    android:id="@+id/etBirthday"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:cursorVisible="false"
                    android:focusable="false"
                    android:focusableInTouchMode="false"
                    android:hint="选择日期"
                    android:inputType="none"
                    android:longClickable="false"
                    android:padding="12dp" />

                <!-- 电话 -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="电话号码"
                    android:textColor="#6B7280"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/etPhone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_input"
                    android:inputType="phone"
                    android:padding="12dp"
                    android:textColor="#111827"
                    android:textColorHint="#9CA3AF" />

                <!-- 身份证 -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="身份证号码"
                    android:textColor="#6B7280"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/etIdCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_input"
                    android:inputType="text"
                    android:padding="12dp"
                    android:textColor="#111827"
                    android:textColorHint="#9CA3AF" />
            </LinearLayout>

            <!-- 卡片2：地址与过敏史 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="地址与过敏史"
                    android:textColor="#111827"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <!-- 地址 -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="地址"
                    android:textColor="#6B7280"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/etAddress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_input"
                    android:gravity="top"
                    android:inputType="textMultiLine"
                    android:minLines="2"
                    android:nestedScrollingEnabled="false"
                    android:padding="12dp"
                    android:textColor="#111827"
                    android:textColorHint="#9CA3AF" />

                <!-- 过敏史 -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="过敏史"
                    android:textColor="#6B7280"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/etAllergy"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_input"
                    android:gravity="top"
                    android:inputType="textMultiLine"
                    android:minLines="2"
                    android:nestedScrollingEnabled="false"
                    android:padding="12dp"
                    android:textColor="#111827"
                    android:textColorHint="#9CA3AF" />
            </LinearLayout>

            <!-- 卡片3：既往史与总体方案 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="既往史与总体方案"
                    android:textColor="#111827"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <!-- 既往史 -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="既往史"
                    android:textColor="#6B7280"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/etMedicalHistory"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_input"
                    android:gravity="top"
                    android:inputType="textMultiLine"
                    android:minLines="3"
                    android:nestedScrollingEnabled="false"
                    android:padding="12dp"
                    android:textColor="#111827"
                    android:textColorHint="#9CA3AF" />

                <!-- 总体方案 -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="总体方案"
                    android:textColor="#6B7280"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/etMasterPlan"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_input"
                    android:gravity="top"
                    android:inputType="textMultiLine"
                    android:minLines="3"
                    android:nestedScrollingEnabled="false"
                    android:padding="12dp"
                    android:textColor="#111827"
                    android:textColorHint="#9CA3AF" />
            </LinearLayout>

            <!-- 给底部按钮留空，避免被 bottomBar 盖住 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="90dp" />

        </LinearLayout>
    </ScrollView>

    <!-- 底部固定操作栏 -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_bottom_bar"
        android:orientation="horizontal"
        android:padding="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <Button
            android:id="@+id/btnSave"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@drawable/bg_primary_button"
            android:text="保存档案"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>