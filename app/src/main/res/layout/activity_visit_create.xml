<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F3F7FF">

    <!-- 顶部标题栏（可选，不喜欢就删） -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:paddingTop="40dp"
        android:paddingBottom="10dp"
        android:text="创建病历"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#111827"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- 可滚动内容 -->
    <ScrollView
        android:id="@+id/svRoot"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingBottom="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintBottom_toTopOf="@id/bottomBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 卡片1：病情与方案 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_card"
                android:padding="14dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="病情与方案"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:textColor="#111827"/>

                <EditText
                    android:id="@+id/etChiefComplaint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_input"
                    android:hint="主诉 ChiefComplaint"
                    android:padding="12dp"
                    android:minLines="2"
                    android:gravity="top"
                    android:inputType="textMultiLine"
                    android:nestedScrollingEnabled="false"
                    android:textColor="#111827"
                    android:textColorHint="#9CA3AF"/>

                <EditText
                    android:id="@+id/etPresentIllness"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_input"
                    android:hint="现病史 PresentIllness"
                    android:padding="12dp"
                    android:minLines="3"
                    android:gravity="top"
                    android:inputType="textMultiLine"
                    android:nestedScrollingEnabled="false"
                    android:textColor="#111827"
                    android:textColorHint="#9CA3AF"/>

                <EditText
                    android:id="@+id/etTreatmentPlan"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_input"
                    android:hint="本诊所治疗方案 TreatmentPlan"
                    android:padding="12dp"
                    android:minLines="3"
                    android:gravity="top"
                    android:inputType="textMultiLine"
                    android:nestedScrollingEnabled="false"
                    android:textColor="#111827"
                    android:textColorHint="#9CA3AF"/>
            </LinearLayout>

            <!-- 卡片2：沟通与预后 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_card"
                android:padding="14dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="沟通与预后"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:textColor="#111827"/>

                <EditText
                    android:id="@+id/etPatientCooperation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_input"
                    android:hint="患者配合程度 PatientCooperation"
                    android:padding="12dp"
                    android:minLines="2"
                    android:gravity="top"
                    android:inputType="textMultiLine"
                    android:nestedScrollingEnabled="false"
                    android:textColor="#111827"
                    android:textColorHint="#9CA3AF"/>

                <EditText
                    android:id="@+id/etDoctorPatientRelation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_input"
                    android:hint="医患关系情况 DoctorPatientRelation"
                    android:padding="12dp"
                    android:minLines="2"
                    android:gravity="top"
                    android:inputType="textMultiLine"
                    android:nestedScrollingEnabled="false"
                    android:textColor="#111827"
                    android:textColorHint="#9CA3AF"/>

                <EditText
                    android:id="@+id/etPrognosisNote"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_input"
                    android:hint="预测发展说明 PrognosisNote"
                    android:padding="12dp"
                    android:minLines="3"
                    android:gravity="top"
                    android:inputType="textMultiLine"
                    android:nestedScrollingEnabled="false"
                    android:textColor="#111827"
                    android:textColorHint="#9CA3AF"/>
            </LinearLayout>

            <!-- 卡片3：附件（先做占位） -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_card"
                android:padding="14dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="附件"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:textColor="#111827"/>

                <TextView
                    android:id="@+id/tvAttachmentEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="暂无附件"
                    android:textSize="13sp"
                    android:textColor="#6B7280"/>

                <FrameLayout
                    android:id="@+id/flAttachmentContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"/>
            </LinearLayout>

            <!-- 给底部固定按钮留空间 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="90dp"/>

        </LinearLayout>
    </ScrollView>

    <!-- 底部固定操作栏 -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_bottom_bar"
        android:padding="12dp"
        android:orientation="horizontal"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <Button
            android:id="@+id/btnSaveVisit"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@drawable/bg_primary_button"
            android:text="保存病历"
            android:textColor="#FFFFFF"
            android:textStyle="bold"/>


    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>