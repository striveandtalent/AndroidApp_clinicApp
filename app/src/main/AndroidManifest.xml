<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.eightbitlab.blurview_sample">
    <!-- 添加网络权限 -->
    <uses-permission android:name="android.permission.INTERNET" /> <!-- 兼容旧安卓保存图片 -->
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/AppTheme"
        android:usesCleartextTraffic="true">
        <activity
            android:name=".VisitDetail.TreatmentRecordEditActivity"
            android:exported="false" />
        <activity
            android:name=".VisitDetail.AttachmentPreviewActivity"
            android:exported="false" />
        <activity
            android:name=".VisitDetail.VisitEditActivity"
            android:exported="false" />
        <activity
            android:name=".VisitDetail.VisitCreateActivity"
            android:exported="false" />
        <activity
            android:name=".PatientDetail.PatientEditActivity"
            android:exported="false" />
        <activity
            android:name=".VisitDetail.VisitDetailActivity"
            android:exported="false" />
        <activity
            android:name=".PatientDetail.PatientDetailActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity" />
        <activity
            android:name=".Patient_Create.CreatePatientActivity"
            android:exported="false" />
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>